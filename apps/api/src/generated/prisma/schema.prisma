generator client {
  provider      = "prisma-client-js"
  output        = "../../../apps/api/src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id              String                 @id @default(cuid())
  userId          String
  name            String
  organization    String?
  roleTitle       String?
  sourceContext   String?
  howCanHelp      String?
  rawInput        String
  notes           String?
  tags            String[]
  domains         String[]
  skills          String[]
  lastContacted   DateTime?
  snoozedUntil    DateTime?
  importanceScore Int                    @default(0)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  embeddings      ContactEmbedding?
  timelineEvents  ContactTimelineEvent[]

  @@index([userId])
  @@index([name])
  @@index([tags], type: Gin)
}

model ContactEmbedding {
  contactId String                      @id
  embedding Unsupported("vector(1536)")
  createdAt DateTime                    @default(now())
  updatedAt DateTime                    @updatedAt
  contact   Contact                     @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model ContactTimelineEvent {
  id        String   @id @default(cuid())
  userId    String
  contactId String
  type      String
  reason    String?
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, createdAt])
  @@index([userId, createdAt])
}
